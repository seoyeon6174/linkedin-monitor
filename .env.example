# Slack incoming webhook for new-post notifications (main channel)
LINKEDIN_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional: Discord webhook for new-post notifications (dual-send with Slack)
DISCORD_WEBHOOK_THREADS=

# Optional: Discord webhook for error notifications (session expiry, parse failures)
DISCORD_WEBHOOK_ERRORS=

# Optional: set to 1/true/yes/on to run without sending any notifications
LINKEDIN_DRY_RUN=0
